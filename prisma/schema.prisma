datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  ADMIN
  OPERATOR
  READONLY
}

enum ClientStatus {
  ACTIVE
  DELINQUENT
  SUSPENDED
  CANCELLED
}

enum ContractStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum OltType {
  VSOL_GPON
  VSOL_EPON
  NONE
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  TRANSFER
  MERCADO_PAGO
  OTHER
}

enum ActionType {
  BLOCK
  UNBLOCK
  SPEED_CHANGE
  TEST_CONNECTION
}

enum ActionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ActionTrigger {
  CRON_JOB
  MANUAL
  PAYMENT
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  fullName  String
  role      UserRole @default(OPERATOR)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  payments Payment[]

  @@map("users")
}

model Client {
  id               String       @id @default(uuid())
  fullName         String       @map("full_name")
  dni              String       @unique
  phone1           String?      @map("phone_1")
  phone2           String?      @map("phone_2")
  email            String?
  address          String       @db.Text
  latitude         Decimal?     @db.Decimal(10, 8)
  longitude        Decimal?     @db.Decimal(11, 8)
  installationDate DateTime?    @map("installation_date")
  status           ClientStatus @default(ACTIVE)
  notes            String?      @db.Text
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  contracts ServiceContract[]
  invoices  Invoice[]
  payments  Payment[]

  @@map("clients")
}

model Plan {
  id              String   @id @default(uuid())
  name            String
  downloadSpeed   Int      @map("download_speed") // In Mbps
  uploadSpeed     Int      @map("upload_speed")   // In Mbps
  price           Decimal  @db.Decimal(10, 2)
  mikrotikProfile String?  @map("mikrotik_profile")
  description     String?  @db.Text
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  contracts ServiceContract[]

  @@map("plans")
}

model Node {
  id               String   @id @default(uuid())
  name             String
  address          String?  @db.Text
  latitude         Decimal? @db.Decimal(10, 8)
  longitude        Decimal? @db.Decimal(11, 8)
  mikrotikHost     String   @map("mikrotik_host")
  mikrotikPort     Int      @default(8728) @map("mikrotik_port")
  mikrotikUser     String   @map("mikrotik_user")
  mikrotikPassword String   @map("mikrotik_password")
  oltHost          String?  @map("olt_host")
  oltType          OltType  @default(NONE) @map("olt_type")
  notes            String?  @db.Text
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  contracts       ServiceContract[]
  mikrotikActions MikrotikAction[]

  @@map("nodes")
}

model ServiceContract {
  id             String         @id @default(uuid())
  clientId       String         @map("client_id")
  planId         String         @map("plan_id")
  nodeId         String         @map("node_id")
  billingDay     Int            @default(5) @map("billing_day") // Day of the month
  graceDays      Int            @default(5) @map("grace_days")   // Days of grace after due date
  pppoeUsername  String?        @map("pppoe_username")
  pppoePassword  String?        @map("pppoe_password")
  staticIp       String?        @map("static_ip")
  macAddress     String?        @map("mac_address")
  onuSerial      String?        @map("onu_serial")
  onuModel       String?        @map("onu_model")
  contractStart  DateTime       @default(now()) @map("contract_start")
  contractEnd    DateTime?      @map("contract_end")
  status         ContractStatus @default(ACTIVE)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id])
  node   Node   @relation(fields: [nodeId], references: [id])

  invoices        Invoice[]
  mikrotikActions MikrotikAction[]

  @@map("service_contracts")
}

model Invoice {
  id            String        @id @default(uuid())
  contractId    String        @map("contract_id")
  clientId      String        @map("client_id")
  invoiceNumber String        @unique @map("invoice_number")
  periodStart   DateTime      @map("period_start")
  periodEnd     DateTime      @map("period_end")
  amount        Decimal       @db.Decimal(10, 2)
  status        InvoiceStatus @default(PENDING)
  dueDate       DateTime      @map("due_date")
  issuedAt      DateTime      @default(now()) @map("issued_at")
  paidAt        DateTime?     @map("paid_at")
  notes         String?       @db.Text
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  contract ServiceContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  client   Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)

  payments Payment[]

  @@map("invoices")
}

model Payment {
  id            String        @id @default(uuid())
  invoiceId     String        @map("invoice_id")
  clientId      String        @map("client_id")
  amount        Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod @default(TRANSFER) @map("payment_method")
  paymentDate   DateTime      @default(now()) @map("payment_date")
  reference     String?
  receivedById  String?       @map("received_by_id")
  notes         String?       @db.Text
  createdAt     DateTime      @default(now()) @map("created_at")

  invoice    Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  client     Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  receivedBy User?   @relation(fields: [receivedById], references: [id])

  @@map("payments")
}

model MikrotikAction {
  id           String        @id @default(uuid())
  contractId   String        @map("contract_id")
  nodeId       String        @map("node_id")
  actionType   ActionType    @map("action_type")
  status       ActionStatus  @default(PENDING)
  executedAt   DateTime      @default(now()) @map("executed_at")
  response     Json?
  errorMessage String?       @map("error_message") @db.Text
  triggeredBy  ActionTrigger @map("triggered_by")
  createdAt    DateTime      @default(now()) @map("created_at")

  contract ServiceContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  node     Node            @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@map("mikrotik_actions")
}
