datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  ADMIN
  OPERATOR
  READONLY
}

enum ClientStatus {
  ACTIVE
  DELINQUENT
  SUSPENDED
  CANCELLED
}

enum ContractStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
  PROVISIONING
  PROVISION_FAILED
  SPEED_SYNC_FAILED
  TERMINATING
  TERMINATION_FAILED
}

enum OltType {
  VSOL_GPON
  VSOL_EPON
  NONE
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  TRANSFER
  MERCADO_PAGO
  OTHER
}

enum ActionType {
  BLOCK
  UNBLOCK
  SPEED_CHANGE
  TEST_CONNECTION
}

enum ActionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ActionTrigger {
  CRON_JOB
  MANUAL
  PAYMENT
}

enum AuditEntity {
  USER
  CLIENT
  PLAN
  NODE
  CONTRACT
  INVOICE
  PAYMENT
  MIKROTIK
  SYSTEM
  IMPORT
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  LOGIN
  LOGOUT
  BLOCK
  UNBLOCK
  PROVISION
  SYNC_SPEED
  TERMINATE
  IMPORT_EXCEL
  EXPORT
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  PARTIAL
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  fullName  String
  role      UserRole @default(OPERATOR)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  payments   Payment[]
  auditLogs  AuditLog[]
  importLogs ImportLog[]

  @@index([email])
  @@index([deletedAt])
  @@map("users")
}

model Client {
  id               String       @id @default(uuid())
  fullName         String       @map("full_name")
  dni              String       @unique
  phone1           String?      @map("phone_1")
  phone2           String?      @map("phone_2")
  email            String?
  address          String       @db.Text
  latitude         Decimal?     @db.Decimal(10, 8)
  longitude        Decimal?     @db.Decimal(11, 8)
  installationDate DateTime?    @map("installation_date")
  status           ClientStatus @default(ACTIVE)
  notes            String?      @db.Text
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  deletedAt        DateTime?    @map("deleted_at")
  deletedBy        String?      @map("deleted_by")

  contracts ServiceContract[]
  invoices  Invoice[]
  payments  Payment[]

  @@index([dni])
  @@index([fullName])
  @@index([status])
  @@index([deletedAt])
  @@map("clients")
}

model Plan {
  id              String   @id @default(uuid())
  name            String
  downloadSpeed   Int      @map("download_speed") // In Mbps
  uploadSpeed     Int      @map("upload_speed")   // In Mbps
  price           Decimal  @db.Decimal(10, 2)
  mikrotikProfile String?  @map("mikrotik_profile")
  description     String?  @db.Text
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  deletedBy       String?   @map("deleted_by")

  contracts ServiceContract[]

  @@index([name])
  @@index([isActive])
  @@index([deletedAt])
  @@map("plans")
}

model Node {
  id               String   @id @default(uuid())
  name             String
  address          String?  @db.Text
  latitude         Decimal? @db.Decimal(10, 8)
  longitude        Decimal? @db.Decimal(11, 8)
  mikrotikHost     String   @map("mikrotik_host")
  mikrotikPort     Int      @default(8728) @map("mikrotik_port")
  mikrotikUser     String   @map("mikrotik_user")
  mikrotikPassword String   @map("mikrotik_password")
  oltHost          String?  @map("olt_host")
  oltType          OltType  @default(NONE) @map("olt_type")
  notes            String?  @db.Text
  isActive         Boolean  @default(true) @map("is_active")
  isInitialized    Boolean  @default(false) @map("is_initialized")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")
  deletedBy        String?   @map("deleted_by")

  contracts       ServiceContract[]
  mikrotikActions MikrotikAction[]

  @@index([name])
  @@index([isActive])
  @@index([deletedAt])
  @@map("nodes")
}

model ServiceContract {
  id             String         @id @default(uuid())
  clientId       String         @map("client_id")
  planId         String         @map("plan_id")
  nodeId         String         @map("node_id")
  billingDay     Int            @default(5) @map("billing_day") // Day of the month
  graceDays      Int            @default(5) @map("grace_days")   // Days of grace after due date
  pppoeUsername  String?        @map("pppoe_username")
  pppoePassword  String?        @map("pppoe_password")
  staticIp       String?        @map("static_ip")
  macAddress     String?        @map("mac_address")
  onuSerial      String?        @map("onu_serial")
  onuModel       String?        @map("onu_model")
  contractStart  DateTime       @default(now()) @map("contract_start")
  contractEnd    DateTime?      @map("contract_end")
  status         ContractStatus @default(ACTIVE)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  deletedAt      DateTime?      @map("deleted_at")
  deletedBy      String?        @map("deleted_by")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id])
  node   Node   @relation(fields: [nodeId], references: [id])

  invoices        Invoice[]
  mikrotikActions MikrotikAction[]

  @@index([clientId])
  @@index([planId])
  @@index([nodeId])
  @@index([status])
  @@index([pppoeUsername])
  @@index([staticIp])
  @@index([deletedAt])
  @@map("service_contracts")
}

model Invoice {
  id            String        @id @default(uuid())
  contractId    String        @map("contract_id")
  clientId      String        @map("client_id")
  invoiceNumber String        @unique @map("invoice_number")
  periodStart   DateTime      @map("period_start")
  periodEnd     DateTime      @map("period_end")
  amount        Decimal       @db.Decimal(10, 2)
  status        InvoiceStatus @default(PENDING)
  dueDate       DateTime      @map("due_date")
  issuedAt      DateTime      @default(now()) @map("issued_at")
  paidAt        DateTime?     @map("paid_at")
  notes         String?       @db.Text
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  deletedAt     DateTime?     @map("deleted_at")
  deletedBy     String?       @map("deleted_by")

  contract ServiceContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  client   Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)

  payments Payment[]

  @@index([contractId])
  @@index([clientId])
  @@index([status])
  @@index([dueDate])
  @@index([deletedAt])
  @@map("invoices")
}

model Payment {
  id            String        @id @default(uuid())
  invoiceId     String        @map("invoice_id")
  clientId      String        @map("client_id")
  amount        Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod @default(TRANSFER) @map("payment_method")
  paymentDate   DateTime      @default(now()) @map("payment_date")
  reference     String?
  receivedById  String?       @map("received_by_id")
  notes         String?       @db.Text
  createdAt     DateTime      @default(now()) @map("created_at")
  deletedAt     DateTime?     @map("deleted_at")
  deletedBy     String?       @map("deleted_by")

  invoice    Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  client     Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  receivedBy User?   @relation(fields: [receivedById], references: [id])

  @@index([invoiceId])
  @@index([clientId])
  @@index([paymentDate])
  @@index([deletedAt])
  @@map("payments")
}

model MikrotikAction {
  id           String        @id @default(uuid())
  contractId   String        @map("contract_id")
  nodeId       String        @map("node_id")
  actionType   ActionType    @map("action_type")
  status       ActionStatus  @default(PENDING)
  executedAt   DateTime      @default(now()) @map("executed_at")
  response     Json?
  errorMessage String?       @map("error_message") @db.Text
  triggeredBy  ActionTrigger @map("triggered_by")
  createdAt    DateTime      @default(now()) @map("created_at")

  contract ServiceContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  node     Node            @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([nodeId])
  @@index([executedAt])
  @@index([status])
  @@map("mikrotik_actions")
}

model AuditLog {
  id              String       @id @default(uuid())
  entity          AuditEntity  // Entidad afectada
  entityId        String?      @map("entity_id") // ID del registro afectado
  action          AuditAction  // Acción realizada
  description     String       @db.Text // Descripción legible
  userId          String?      @map("user_id") // Usuario que realizó la acción
  userEmail       String?      @map("user_email") // Email del usuario (desnormalizado)
  ipAddress       String?      @map("ip_address") // IP desde donde se realizó
  userAgent       String?      @map("user_agent") // Navegador/dispositivo
  dataBefore      Json?        @map("data_before") // Estado anterior (JSON)
  dataAfter       Json?        @map("data_after") // Estado nuevo (JSON)
  changes         Json?        // Solo los campos que cambiaron
  success         Boolean      @default(true) // Si la acción fue exitosa
  errorMessage    String?      @map("error_message") @db.Text
  executionTimeMs Int?         @map("execution_time_ms") // Tiempo de ejecución
  createdAt       DateTime     @default(now()) @map("created_at")
  
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}

model ImportLog {
  id            String       @id @default(uuid())
  fileName      String       @map("file_name")
  fileSize      Int          @map("file_size") // bytes
  totalRows     Int          @map("total_rows")
  processedRows Int          @default(0) @map("processed_rows")
  successRows   Int          @default(0) @map("success_rows")
  failedRows    Int          @default(0) @map("failed_rows")
  skippedRows   Int          @default(0) @map("skipped_rows")
  status        ImportStatus @default(PENDING)
  errors        Json?        // Array de errores por fila
  warnings      Json?        // Array de warnings
  summary       Json?        // Resumen de la importación
  userId        String       @map("user_id")
  startedAt     DateTime?    @map("started_at")
  completedAt   DateTime?    @map("completed_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  
  user User @relation(fields: [userId], references: [id])
  
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("import_logs")
}
